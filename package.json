{
  "name": "oracle",
  "version": "1.0.0",
  "description": "Lightweight API-only CLI for multi-model LLM queries",
  "type": "module",
  "main": "dist/bin/oracle-cli.js",
  "bin": {
    "oracle": "dist/bin/oracle-cli.js"
  },
  "scripts": {
    "docs:list": "tsx scripts/docs-list.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "npm run build && node ./dist/scripts/run-cli.js",
    "oracle": "npm start",
    "check": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && biome lint .",
    "test": "vitest run",
    "test:live": "ORACLE_LIVE_TEST=1 vitest run tests/live --exclude tests/live/openai-live.test.ts",
    "test:pro": "ORACLE_LIVE_TEST=1 vitest run tests/live/openai-live.test.ts",
    "test:smoke": "bash scripts/smoke-test.sh",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*",
    "MODELS.md",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steipete/oracle.git"
  },
  "engines": {
    "node": ">=22"
  },
  "devEngines": {
    "runtime": [
      {
        "name": "node",
        "version": ">=22"
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/steipete/oracle/issues"
  },
  "homepage": "https://github.com/steipete/oracle#readme",
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@google/genai": "^1.41.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.3",
    "gpt-tokenizer": "^3.4.0",
    "kleur": "^4.1.5",
    "markdansi": "0.2.1",
    "openai": "^6.21.0",
    "osc-progress": "^0.3.0",
    "tokentally": "^0.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "4.0.18",
    "es-toolkit": "^1.44.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
